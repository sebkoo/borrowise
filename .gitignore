# ─────────────────────────────────────────────────────
# Node
# ─────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# ─────────────────────────────────────────────────────
# Expo
# ─────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ─────────────────────────────────────────────────────
# EAS / native signing artifacts
# ─────────────────────────────────────────────────────
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ─────────────────────────────────────────────────────
# React Native / Metro
# ─────────────────────────────────────────────────────
.metro-health-check*

# ─────────────────────────────────────────────────────
# iOS / Xcode
# ─────────────────────────────────────────────────────
ios/Pods/
ios/build/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
DerivedData/
*.xcuserstate
*.hmap
*.ipa
*.dSYM
*.dSYM.zip

# ─────────────────────────────────────────────────────
# Android
# ─────────────────────────────────────────────────────
android/.gradle/
android/app/build/
android/build/
*.keystore
!debug.keystore

# ─────────────────────────────────────────────────────
# Environment & secrets (never commit real keys)
# ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────
# Testing / coverage
# ─────────────────────────────────────────────────────
coverage/

# ─────────────────────────────────────────────────────
# E2E (Maestro)
# Flow YAMLs under .maestro/ ARE committed (see commit #9);
# ignore only transient run outputs. Recordings live in docs/media/.
# ─────────────────────────────────────────────────────
maestro-report*.xml
*.maestro.mp4

# ─────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ─────────────────────────────────────────────────────
# Editors / IDEs
# ─────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# ─────────────────────────────────────────────────────
# Native projects (CNG — generated by `expo prebuild`, never committed)
# ─────────────────────────────────────────────────────
/ios
/android
